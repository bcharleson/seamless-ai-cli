{
  "name": "seamless-ai-cli",
  "version": "0.1.2",
  "description": "CLI and MCP server for the Seamless.ai B2B prospecting platform — contact search, company search, research, and org data",
  "type": "module",
  "bin": {
    "seamless": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md",
    "CLAUDE.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "seamless",
    "seamless-ai",
    "b2b",
    "prospecting",
    "lead-generation",
    "contacts",
    "companies",
    "sales",
    "cli",
    "mcp",
    "ai-agent",
    "automation",
    "outbound"
  ],
  "author": "Brandon Charleson",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^14.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
